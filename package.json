{
  "name": "github-repositories-fllow",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "build:lambda": "pnpm --filter web build && pnpm --filter server build && node scripts/copy-web-to-server.mjs",
    "check-types": "pnpm -r check-types",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "db:push": "pnpm --filter @github-repositories-fllow/db db:push",
    "db:studio": "pnpm --filter @github-repositories-fllow/db db:studio",
    "db:generate": "pnpm --filter @github-repositories-fllow/db db:generate",
    "db:migrate": "pnpm --filter @github-repositories-fllow/db db:migrate"
  },
  "dependencies": {
    "@github-repositories-fllow/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@github-repositories-fllow/config": "workspace:*",
    "@types/node": "^22.13.14",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.9.0"
}
